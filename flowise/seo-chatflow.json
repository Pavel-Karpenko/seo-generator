      "data": {
        "id": "chatPromptTemplate_0",
        "label": "Chat Prompt Template",
        "version": 1,
        "name": "chatPromptTemplate",
        "type": "ChatPromptTemplate",
        "baseClasses": ["ChatPromptTemplate", "BaseChatPromptTemplate", "BasePromptTemplate"],
        "category": "Prompts",
        "description": "Schema to represent a chat prompt",
        "inputParams": [
          {
            "label": "System Message",
            "name": "systemMessagePrompt",
            "type": "string",
            "rows": 10,
            "placeholder": "You are a helpful assistant that translates {input_language} to {output_language}.",
            "id": "chatPromptTemplate_0-input-systemMessagePrompt-string"
          },
          {
            "label": "Human Message",
            "name": "humanMessagePrompt",
            "type": "string",
            "rows": 4,
            "placeholder": "{input}",
            "id": "chatPromptTemplate_0-input-humanMessagePrompt-string"
          },
          {
            "label": "Format Prompt Values",
            "name": "promptValues",
            "type": "json",
            "optional": true,
            "acceptVariable": true,
            "list": true,
            "id": "chatPromptTemplate_0-input-promptValues-json"
          }
        ],
        "inputAnchors": [],
        "inputs": {
          "systemMessagePrompt": "You are an SEO copywriter. Given a product, return ONLY a JSON object with these exact keys: title, meta_description, h1, description, bullets.\n\nExample:\nProduct: Leather Wallet, Category: Accessories, Keywords: slim, rfid, genuine leather\nOutput: {\"title\":\"Slim RFID Leather Wallet for Men\",\"meta_description\":\"Premium genuine leather wallet with RFID blocking. Slim design fits any pocket. Shop now.\",\"h1\":\"Slim Genuine Leather RFID Blocking Wallet\",\"description\":\"Crafted from genuine leather, this slim wallet features RFID blocking technology to protect your cards. Its minimalist design holds up to 8 cards and cash without bulk. Perfect for everyday carry.\",\"bullets\":[\"RFID blocking protects your credit cards\",\"Genuine leather for durability and style\",\"Slim profile fits comfortably in any pocket\",\"Holds up to 8 cards and cash\"]}\n\nNow generate for the product in the user message. Return ONLY the JSON, nothing else.",
          "humanMessagePrompt": "{input}",
          "promptValues": "{\"product_name\": \"\", \"category\": \"\", \"keywords\": \"\"}"
        },
        "outputAnchors": [
          {
            "id": "chatPromptTemplate_0-output-chatPromptTemplate-ChatPromptTemplate|BaseChatPromptTemplate|BasePromptTemplate",
            "name": "chatPromptTemplate",
            "label": "ChatPromptTemplate",
            "description": "",
            "type": "ChatPromptTemplate | BaseChatPromptTemplate | BasePromptTemplate"
          }
        ],
        "outputs": {},
        "selected": false
